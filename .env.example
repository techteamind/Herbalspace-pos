# ============================================
# Herbaspace POS — Environment Variables
# Salin file ini menjadi `.env` dan isi nilainya.
# Variabel VITE_* boleh terekspos ke klien (frontend).
# Variabel TANPA prefix VITE_ hanya untuk serverless API (rahasia).
# ============================================

# --- Supabase Auth (autentikasi saja, BUKAN database) ---
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
# Untuk verifikasi JWT di sisi API (Project Settings > API > JWT Secret)
SUPABASE_JWT_SECRET="your-jwt-secret"

# --- Supabase Service Role (untuk admin operations seperti change password) ---
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Vercel Postgres (database utama, dipakai oleh /api dan Drizzle) ---
# Diisi otomatis oleh Vercel saat integrasi Storage; untuk lokal salin dari dashboard.
POSTGRES_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Capacitor / Android (opsional, untuk build native app) ---
# Base URL API saat app berjalan sebagai native (karena /api/ tidak ada secara lokal).
# Kosongkan jika menjalankan di browser (dev mode).
# VITE_API_BASE="https://your-vercel-domain.vercel.app"
